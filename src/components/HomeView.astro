---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from './ArticleCard.astro';
import Newsletter from './Newsletter.astro';
import { getEntries, articlesFor, pagesFor, homeFor, urlFor } from '../lib/notion';
import { t } from '../i18n/dict';
import type { ContentBlock, Locale } from '../lib/types';

interface Props {
  locale: Locale;
  autoDetect?: boolean;
}
const { locale, autoDetect = false } = Astro.props;

const entries = await getEntries();
const home = homeFor(entries, locale);
const articles = articlesFor(entries, locale);
const navPages = pagesFor(entries, locale).map((p) => ({ title: p.title, path: urlFor(p) }));
const homePath = locale === 'pl' ? '/pl/' : '/';

const translationPath = home?.translation ? urlFor(home.translation) : undefined;
const translationLocale = home?.translation?.locale;

// Treść hero pochodzi z TREŚCI notatki HP w Notion, nie z pola „tytuł"
// (tytuł to teraz tylko wewnętrzna nazwa wpisu). Pierwszy nagłówek w treści =
// wielki tytuł hero; kursywa (<em>) w nim dostaje animowany gradient. Pozostałe
// bloki (akapit „Notes from…") = lead pod tytułem, nad zapisem na newsletter.
const heroBlocks: ContentBlock[] = home?.content ?? [];
const headingIdx = heroBlocks.findIndex(
  (b) => b.type === 'h1' || b.type === 'h2' || b.type === 'h3',
);
const headingHtml = headingIdx >= 0 ? heroBlocks[headingIdx].html : undefined;
const leadBlocks = heroBlocks.filter((_, i) => i !== headingIdx);

// Wersja czysto-tekstowa (bez tagów HTML) do <title>, OG i opisu SEO.
const unescape = (s: string): string =>
  s
    .replace(/<[^>]+>/g, '')
    .replace(/&amp;/g, '&')
    .replace(/&quot;/g, '"')
    .replace(/&lt;/g, '<')
    .replace(/&gt;/g, '>')
    .trim();

const heroTitle = headingHtml ? unescape(headingHtml) : (home?.title ?? t('siteName', locale));
const firstParagraph = leadBlocks.find((b) => b.type === 'p' && b.html)?.html;
const description = firstParagraph ? unescape(firstParagraph).slice(0, 200) : undefined;
---

<BaseLayout
  locale={locale}
  title={heroTitle}
  description={description}
  cover={home?.cover}
  homePath={homePath}
  navPages={navPages}
  translationPath={translationPath}
  translationLocale={translationLocale}
>
  {
    autoDetect && (
      <script slot="head" is:inline>
        {`(function(){try{if(location.pathname!=='/')return;if(localStorage.getItem('langChosen'))return;var l=(navigator.language||'').toLowerCase();if(l.indexOf('pl')===0)location.replace('/pl/');}catch(e){}})();`}
      </script>
    )
  }

  <section class="hero">
    <div class="hero-orb" aria-hidden="true"></div>
    <div class="hero-container">
      <div class="hero-inner">
        <p class="eyebrow">{t('heroTagline', locale)}</p>
        {
          headingHtml ? (
            <h1 class="hero-title" set:html={headingHtml} />
          ) : (
            <h1 class="hero-title">{heroTitle}</h1>
          )
        }
        <div class="hero-lead">
          {leadBlocks.map((b) => (b.type === 'p' && b.html ? <p set:html={b.html} /> : null))}
        </div>

        <Newsletter locale={locale} variant="hero" />
      </div>
    </div>
  </section>

  <section class="posts" aria-labelledby="posts-heading">
    <h2 id="posts-heading" class="posts-heading">{t('latestPosts', locale)}</h2>
    {
      articles.length ? (
        <div class="posts-grid">
          {articles.map((a) => (
            <ArticleCard entry={a} locale={locale} />
          ))}
        </div>
      ) : (
        <p class="empty">{t('noPosts', locale)}</p>
      )
    }
  </section>

</BaseLayout>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    width: 100vw;
    margin-left: calc(50% - 50vw);
    padding: clamp(36px, 6vw, 60px) 0 clamp(40px, 6vw, 58px);
  }
  .hero-container {
    max-width: var(--page-max);
    margin: 0 auto;
    padding: 0 var(--page-pad);
  }
  .hero-orb {
    position: absolute;
    right: -70px;
    top: -50px;
    width: clamp(190px, 32vw, 340px);
    height: clamp(190px, 32vw, 340px);
    border-radius: 50%;
    background: conic-gradient(
      from 0deg,
      var(--g-gold),
      var(--g-orange),
      var(--g-magenta),
      var(--g-purple),
      var(--g-gold)
    );
    filter: blur(4px);
    opacity: 0.9;
    animation: spinSlow 34s linear infinite;
    -webkit-mask-image: radial-gradient(circle, #000 42%, transparent 62%);
    mask-image: radial-gradient(circle, #000 42%, transparent 62%);
    pointer-events: none;
  }
  .hero-inner {
    position: relative;
    max-width: 720px;
  }
  .eyebrow {
    margin: 0 0 20px;
    font: italic 400 13px var(--font-serif);
    color: var(--color-accent);
  }
  .hero-title {
    margin: 0;
    font: 500 clamp(34px, 6vw, 62px) / 1.06 var(--font-serif);
    letter-spacing: -0.015em;
    color: var(--color-text);
  }
  /* Kursywa w tytule (Notion <em>) = animowany, kolorowy gradient. */
  .hero-title :global(em) {
    font-style: italic;
    background: linear-gradient(
      90deg,
      var(--g-orange),
      var(--g-magenta),
      var(--g-purple),
      var(--g-orange)
    );
    background-size: 300% 100%;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    animation: gradShift 8s ease infinite;
  }
  .hero-lead :global(p) {
    margin: 28px 0 0;
    max-width: 540px;
    font: 400 clamp(16px, 2.4vw, 18px) / 1.7 var(--font-serif);
    color: var(--color-muted);
  }

  .posts {
    padding-bottom: var(--space-6);
  }
  .posts-heading {
    margin: 0 0 22px;
    font: italic 400 15px var(--font-serif);
    color: var(--color-muted);
  }
  .posts-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 26px;
  }
  @media (max-width: 640px) {
    .posts-grid {
      grid-template-columns: 1fr;
      gap: 18px;
    }
  }
  .empty {
    color: var(--color-muted);
    font-style: italic;
  }
</style>
