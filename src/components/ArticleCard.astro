---
import Cover from './Cover.astro';
import type { Entry, Locale } from '../lib/types';
import { urlFor } from '../lib/notion';

interface Props {
  entry: Entry;
  locale: Locale;
}
const { entry } = Astro.props;
const href = urlFor(entry);

// Krótka data w stylu „09 JUL" (miesiąc + dzień, wersalikami, zależne od języka).
const dateLabel = entry.publishedAt
  ? new Date(entry.publishedAt)
      .toLocaleDateString(entry.locale === 'pl' ? 'pl-PL' : 'en-GB', {
        month: 'short',
        day: '2-digit',
      })
      .toUpperCase()
  : undefined;

const category = entry.categories[0];
const meta = [dateLabel, category?.toUpperCase()].filter(Boolean).join(' · ');

// Gradient-placeholder dla kart bez okładki — deterministyczny wybór z 4 wariantów.
const GRADIENTS = [
  'conic-gradient(from 210deg at 30% 30%, #f5a623, #e0592f, #f6f2ea, #f5a623)',
  'conic-gradient(from 120deg at 70% 40%, #7c4fd4, #c23b7a, #f6f2ea, #7c4fd4)',
  'linear-gradient(135deg, #f5a623, #c23b7a 60%, #7c4fd4)',
  'conic-gradient(from 300deg at 50% 60%, #e0592f, #f5a623, #f6f2ea, #e0592f)',
];
let hash = 0;
for (const ch of entry.id) hash = (hash + ch.charCodeAt(0)) % GRADIENTS.length;
const gradient = GRADIENTS[hash];
---

<article class="card">
  <a class="card-link" href={href}>
    <div class="card-cover">
      {
        entry.cover ? (
          <Cover src={entry.cover} alt={entry.title} />
        ) : (
          <div class="card-cover-grad" style={`background:${gradient}`} role="img" aria-label={entry.title} />
        )
      }
    </div>
    <div class="card-body">
      {meta && <div class="card-meta">{meta}</div>}
      <h3 class="card-title">{entry.title}</h3>
      {entry.excerpt && <p class="card-excerpt">{entry.excerpt}</p>}
      {
        entry.tags.length > 0 && (
          <div class="card-tags">
            {entry.tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )
      }
    </div>
  </a>
</article>

<style>
  .card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
    transition:
      transform 0.18s ease,
      box-shadow 0.18s ease;
  }
  .card:hover {
    transform: translateY(-3px);
    box-shadow: 0 18px 40px -22px rgba(0, 0, 0, 0.35);
  }
  .card-link {
    display: block;
    color: inherit;
    text-decoration: none;
  }
  .card-cover,
  .card-cover-grad {
    height: 132px;
  }
  .card-cover {
    overflow: hidden;
  }
  .card-cover :global(.cover) {
    height: 132px;
  }
  .card-body {
    padding: 20px 22px 22px;
  }
  .card-meta {
    font: 400 11px var(--font-mono);
    letter-spacing: 0.01em;
    color: var(--color-accent);
    margin-bottom: 9px;
  }
  .card-title {
    margin: 0;
    font: 500 24px/1.2 var(--font-serif);
    letter-spacing: -0.01em;
    color: var(--color-text);
  }
  .card-excerpt {
    margin: 10px 0 0;
    font: 400 14px/1.55 var(--font-serif);
    color: var(--color-muted-2);
  }
  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
    margin-top: 14px;
  }
  .tag {
    font: 400 11px var(--font-mono);
    color: var(--color-accent);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 3px 10px;
  }
  @media (max-width: 640px) {
    .card-title {
      font-size: 20px;
    }
  }
</style>
