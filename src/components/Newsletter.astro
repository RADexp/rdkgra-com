---
// Formularz zapisu na newsletter — jeden komponent, dwa warianty:
//  • hero — wpleciony w hero strony głównej (bez ramki),
//  • card — kartka na dole artykułu (ramka + wirujący orb + nagłówek).
// Wysyłka do /api/subscribe (zapis w Notion). Logika submitu na dole pliku
// obsługuje wszystkie formularze [data-subscribe] na stronie.
import { t } from '../i18n/dict';
import type { Locale } from '../lib/types';

interface Props {
  locale: Locale;
  variant?: 'hero' | 'card';
}
const { locale, variant = 'hero' } = Astro.props;
---

<div class:list={['nl', `nl--${variant}`]}>
  {variant === 'card' && <div class="nl-orb" aria-hidden="true" />}

  <div class="nl-inner">
    {
      variant === 'card' && (
        <>
          <div class="nl-eyebrow">{t('nlCardEyebrow', locale)}</div>
          <div class="nl-heading">{t('nlCardHeading', locale)}</div>
        </>
      )
    }

    <form
      class="subscribe"
      data-subscribe
      method="post"
      action="/api/subscribe"
      data-msg-loading={t('subscribeLoading', locale)}
      data-msg-ok={t('subscribeOk', locale)}
      data-msg-already={t('subscribeAlready', locale)}
      data-msg-invalid={t('subscribeInvalid', locale)}
      data-msg-error={t('subscribeError', locale)}
    >
      <input
        type="email"
        name="email"
        required
        autocomplete="email"
        placeholder={t('subscribePlaceholder', locale)}
        aria-label={t('subscribePlaceholder', locale)}
      />
      <input type="hidden" name="locale" value={locale} />
      {/* Pułapka na boty — ukryta przed ludźmi; nie wypełniać. */}
      <input
        class="hp-field"
        type="text"
        name="company"
        tabindex="-1"
        autocomplete="off"
        aria-hidden="true"
      />
      <button type="submit">{t('subscribeCta', locale)}</button>
    </form>
    <p class="subscribe-note" data-subscribe-note aria-live="polite">{t('subscribeNote', locale)}</p>
  </div>
</div>

{/* Zapis na newsletter → wysyłka do /api/subscribe (zapis w Notion). */}
<script is:inline>
  (function () {
    var forms = document.querySelectorAll('[data-subscribe]');
    for (var i = 0; i < forms.length; i++) {
      (function (form) {
        if (form.dataset.subscribeReady) return;
        form.dataset.subscribeReady = '1';
        var note =
          (form.parentElement && form.parentElement.querySelector('[data-subscribe-note]')) ||
          document.querySelector('[data-subscribe-note]');
        var msg = function (k) {
          return form.getAttribute('data-msg-' + k);
        };
        form.addEventListener('submit', function (e) {
          e.preventDefault();
          var btn = form.querySelector('button');
          var email = form.email.value.trim();
          if (note) note.textContent = msg('loading');
          if (btn) btn.disabled = true;
          fetch(form.action, {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify({
              email: email,
              locale: form.locale ? form.locale.value : '',
              company: form.company ? form.company.value : '',
            }),
          })
            .then(function (r) {
              return r.json().then(function (d) {
                return { status: r.status, data: d };
              });
            })
            .then(function (res) {
              if (res.data && res.data.ok) {
                form.reset();
                if (note) note.textContent = res.data.already ? msg('already') : msg('ok');
              } else if (res.status === 422) {
                if (note) note.textContent = msg('invalid');
              } else {
                if (note) note.textContent = msg('error');
              }
            })
            .catch(function () {
              if (note) note.textContent = msg('error');
            })
            .finally(function () {
              if (btn) btn.disabled = false;
            });
        });
      })(forms[i]);
    }
  })();
</script>

<style>
  /* ── wspólny formularz ──────────────────────────────────────────────── */
  .subscribe {
    display: flex;
    gap: 14px;
    align-items: flex-end;
  }
  .subscribe input[type='email'] {
    flex: 1;
    min-width: 0;
    background: transparent;
    border: none;
    border-bottom: 1.5px solid var(--color-text);
    outline: none;
    font: 400 16px var(--font-serif);
    color: var(--color-text);
    padding-bottom: 9px;
  }
  .subscribe input::placeholder {
    color: var(--color-subtle);
  }
  .subscribe button {
    font: 600 15px var(--font-serif);
    padding: 12px 26px;
    border: none;
    border-radius: 999px;
    background: var(--grad-brand);
    color: #fffdf8;
    cursor: pointer;
    white-space: nowrap;
    box-shadow: 0 8px 20px -8px rgba(124, 79, 212, 0.6);
    transition:
      transform 0.15s ease,
      box-shadow 0.15s ease;
  }
  .subscribe button:hover {
    transform: translateY(-1px);
    box-shadow: 0 12px 24px -8px rgba(124, 79, 212, 0.7);
  }
  .subscribe button:disabled {
    opacity: 0.6;
    cursor: default;
    transform: none;
  }
  /* Pułapka na boty — poza ekranem, niewidoczna, pomijana przez czytniki. */
  .hp-field {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
    pointer-events: none;
  }
  .subscribe-note {
    margin: 12px 0 0;
    font: 400 12px var(--font-mono);
    color: var(--color-subtle);
  }

  /* ── wariant hero ───────────────────────────────────────────────────── */
  .nl--hero {
    margin-top: 34px;
    max-width: 440px;
  }

  /* ── wariant card (dół artykułu) ────────────────────────────────────── */
  .nl--card {
    position: relative;
    overflow: hidden;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 18px;
    padding: 34px 36px;
  }
  .nl-orb {
    position: absolute;
    right: -60px;
    bottom: -70px;
    width: 220px;
    height: 220px;
    border-radius: 50%;
    background: conic-gradient(
      from 0deg,
      var(--g-gold),
      var(--g-orange),
      var(--g-magenta),
      var(--g-purple),
      var(--g-gold)
    );
    opacity: 0.85;
    animation: spinSlow 34s linear infinite;
    -webkit-mask-image: radial-gradient(circle, #000 42%, transparent 62%);
    mask-image: radial-gradient(circle, #000 42%, transparent 62%);
    pointer-events: none;
  }
  .nl--card .nl-inner {
    position: relative;
    max-width: 420px;
  }
  .nl-eyebrow {
    font: italic 400 13px var(--font-serif);
    color: var(--color-accent);
    margin-bottom: 10px;
  }
  .nl-heading {
    font: 500 27px/1.15 var(--font-serif);
    letter-spacing: -0.01em;
    color: var(--color-text);
  }
  .nl--card .subscribe {
    margin-top: 22px;
  }

  @media (max-width: 640px) {
    .subscribe {
      gap: 10px;
    }
    .nl--card {
      padding: 24px;
      border-radius: 16px;
    }
    .nl-orb {
      width: 150px;
      height: 150px;
      right: -40px;
      bottom: -50px;
    }
    .nl-heading {
      font-size: 21px;
    }
    .nl--card .subscribe {
      flex-direction: column;
      align-items: stretch;
      gap: 14px;
    }
    .nl--card .subscribe button {
      width: 100%;
    }
  }
</style>
