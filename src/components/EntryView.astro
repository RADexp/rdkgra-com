---
import BaseLayout from '../layouts/BaseLayout.astro';
import Cover from './Cover.astro';
import ContentBody from './ContentBody.astro';
import Newsletter from './Newsletter.astro';
import { getEntries, pagesFor, urlFor } from '../lib/notion';
import { t } from '../i18n/dict';
import type { Entry, Locale } from '../lib/types';

interface Props {
  entry: Entry;
  locale: Locale;
}
const { entry, locale } = Astro.props;

const entries = await getEntries();
const navPages = pagesFor(entries, locale).map((p) => ({ title: p.title, path: urlFor(p) }));
const homePath = locale === 'pl' ? '/pl/' : '/';

const translationPath = entry.translation ? urlFor(entry.translation) : undefined;
const translationLocale = entry.translation?.locale;

// Pigułka przełącznika języka w rzędzie tagów — tekst zawsze w języku DOCELOWYM.
const langPillLabel = locale === 'en' ? 'Czytaj po polsku' : 'Read in English';
const langPillFlag = locale === 'en' ? 'pl' : 'en';

const description =
  entry.excerpt ??
  entry.content.find((b) => b.type === 'p' && b.html)?.html?.replace(/<[^>]+>/g, '').slice(0, 200);

const isArticle = entry.type === 'article';

// Data w stylu „JUL 09, 2026" / „09 LIP 2026" (wersaliki, zależne od języka).
const dateLabel =
  isArticle && entry.publishedAt
    ? new Date(entry.publishedAt)
        .toLocaleDateString(locale === 'pl' ? 'pl-PL' : 'en-US', {
          year: 'numeric',
          month: 'short',
          day: '2-digit',
        })
        .toUpperCase()
    : undefined;

// Szacowany czas czytania (~200 słów/min) z treści wpisu.
const words = entry.content
  .map((b) => {
    if (b.type === 'code') return b.code ?? '';
    if (b.items) return b.items.join(' ');
    return b.html ?? '';
  })
  .join(' ')
  .replace(/<[^>]+>/g, ' ')
  .trim();
const wordCount = words ? words.split(/\s+/).length : 0;
const readMin = Math.max(1, Math.round(wordCount / 200));
const readLabel = isArticle ? `${readMin} ${t('minRead', locale)}` : undefined;

const category = entry.categories[0];
const meta = [dateLabel, category?.toUpperCase(), readLabel].filter(Boolean).join(' · ');

// Kanoniczny URL wpisu — do przycisków udostępniania.
const site = Astro.site ?? new URL('https://radekgrabarek.com');
const shareUrl = new URL(Astro.url.pathname, site).href;
const xShare = `https://twitter.com/intent/tweet?text=${encodeURIComponent(entry.title)}&url=${encodeURIComponent(shareUrl)}`;
const liShare = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(shareUrl)}`;
---

<BaseLayout
  locale={locale}
  title={entry.title}
  description={description}
  cover={entry.cover}
  homePath={homePath}
  navPages={navPages}
  translationPath={translationPath}
  translationLocale={translationLocale}
>
  <article class="entry">
    <a class="entry-back" href={homePath}>{t('backToWriting', locale)}</a>

    <header class="entry-header">
      {meta && <div class="entry-meta">{meta}</div>}
      <h1 class="entry-title">{entry.title}</h1>

      {
        (entry.tags.length > 0 || translationPath) && (
          <div class="entry-tags">
            {entry.tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
            {translationPath && (
              <a class="lang-pill" href={translationPath} rel="alternate" hreflang={translationLocale}>
                <span class={`lang-pill-flag flag-${langPillFlag}`} aria-hidden="true"></span>
                {langPillLabel}
              </a>
            )}
          </div>
        )
      }

      <div class="byline">
        <span class="byline-avatar" aria-hidden="true"></span>
        <div>
          <div class="byline-name">{t('siteName', locale)}</div>
          <div class="byline-tagline">{t('authorTagline', locale)}</div>
        </div>
      </div>
    </header>

    {
      entry.cover && (
        <div class="entry-cover">
          <Cover src={entry.cover} alt={entry.title} />
        </div>
      )
    }

    <ContentBody blocks={entry.content} />

    <div class="share">
      <span class="share-label">{t('shareThis', locale)}</span>
      <div class="share-links">
        <a
          class="share-btn"
          href={xShare}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={t('shareOnX', locale)}
          title={t('shareOnX', locale)}>X</a
        >
        <a
          class="share-btn"
          href={liShare}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={t('shareOnLinkedIn', locale)}
          title={t('shareOnLinkedIn', locale)}>in</a
        >
        <button
          class="share-btn"
          type="button"
          data-copy-link
          data-url={shareUrl}
          data-copied={t('copiedLink', locale)}
          aria-label={t('copyLink', locale)}
          title={t('copyLink', locale)}>↗</button
        >
      </div>
    </div>

    <div class="entry-newsletter">
      <Newsletter locale={locale} variant="card" />
    </div>
  </article>

  <script is:inline>
    (function () {
      var btn = document.querySelector('[data-copy-link]');
      if (!btn) return;
      btn.addEventListener('click', function () {
        var url = btn.getAttribute('data-url') || location.href;
        var done = function () {
          var prev = btn.textContent;
          btn.textContent = '✓';
          btn.setAttribute('title', btn.getAttribute('data-copied') || '');
          setTimeout(function () {
            btn.textContent = prev;
          }, 1600);
        };
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(url).then(done).catch(function () {});
        } else {
          try {
            var ta = document.createElement('textarea');
            ta.value = url;
            document.body.appendChild(ta);
            ta.select();
            document.execCommand('copy');
            document.body.removeChild(ta);
            done();
          } catch (_) {}
        }
      });
    })();
  </script>
</BaseLayout>

<style>
  .entry {
    max-width: var(--content-width);
    margin: 0 auto;
    padding-top: clamp(36px, 5vw, 56px);
  }

  .entry-back {
    font: italic 400 13px var(--font-serif);
    color: var(--color-accent);
    text-decoration: none;
  }
  .entry-back:hover {
    color: var(--g-magenta);
  }

  .entry-header {
    margin-top: 26px;
  }
  .entry-meta {
    font: 400 12px var(--font-mono);
    letter-spacing: 0.04em;
    color: var(--color-accent);
    margin-bottom: 16px;
  }
  .entry-title {
    margin: 0;
    font: 500 clamp(31px, 5.5vw, 54px) / 1.08 var(--font-serif);
    letter-spacing: -0.02em;
    color: var(--color-text);
  }

  .entry-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
    margin-top: 24px;
  }
  .tag {
    font: 400 11px var(--font-mono);
    color: var(--color-accent);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 3px 10px;
  }

  .lang-pill {
    display: flex;
    align-items: center;
    gap: 6px;
    font: 400 11px var(--font-mono);
    color: #57503f;
    text-decoration: none;
    border: 1px solid #d8c9ad;
    border-radius: 999px;
    padding: 3px 10px 3px 6px;
    background: #fffdf8;
    cursor: pointer;
    transition:
      background-color 0.15s ease,
      border-color 0.15s ease,
      color 0.15s ease;
  }
  .lang-pill:hover {
    background: #f6efe0;
    border-color: #c9b892;
    color: var(--color-accent);
  }

  .lang-pill-flag {
    display: block;
    width: 16px;
    height: 11px;
    flex: none;
    border-radius: 2px;
    overflow: hidden;
    box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.08);
  }
  .lang-pill-flag.flag-pl {
    background: linear-gradient(to bottom, #fdfaf2 0 50%, #c9503a 50% 100%);
  }
  .lang-pill-flag.flag-en {
    background: linear-gradient(to bottom, #3c5a99 0 50%, #c9503a 50% 100%);
  }

  .byline {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 28px;
    padding-top: 24px;
    border-top: 1px solid var(--color-border);
  }
  .byline-avatar {
    width: 40px;
    height: 40px;
    flex: none;
    border-radius: 50%;
    background: conic-gradient(
      from 200deg,
      var(--g-gold),
      var(--g-orange),
      var(--g-magenta),
      var(--g-purple),
      var(--g-gold)
    );
  }
  .byline-name {
    font: 500 15px var(--font-serif);
    color: var(--color-text);
  }
  .byline-tagline {
    font: 400 12px var(--font-mono);
    color: var(--color-subtle);
  }

  .entry-cover {
    aspect-ratio: 16 / 9;
    border-radius: var(--radius);
    overflow: hidden;
    margin-top: 40px;
  }

  /* treść (ContentBody) sama trzyma odstęp od góry przez margin pierwszego bloku;
     dodajemy zapas nad prozą */
  .entry :global(.content-body) {
    margin-top: 40px;
  }

  .share {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-top: 40px;
    padding-top: 24px;
    border-top: 1px solid var(--color-border);
  }
  .share-label {
    font: 500 11px var(--font-mono);
    color: var(--color-subtle);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .share-links {
    display: flex;
    gap: 9px;
  }
  .share-btn {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid #d8c9ad;
    background: transparent;
    display: flex;
    align-items: center;
    justify-content: center;
    font: 500 12px var(--font-mono);
    color: var(--color-muted);
    text-decoration: none;
    cursor: pointer;
    transition:
      border-color 0.15s ease,
      color 0.15s ease;
  }
  .share-btn:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .entry-newsletter {
    margin: 56px 0 8px;
  }
</style>
