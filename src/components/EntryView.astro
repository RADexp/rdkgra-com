---
import BaseLayout from '../layouts/BaseLayout.astro';
import Cover from './Cover.astro';
import ContentBody from './ContentBody.astro';
import { getEntries, pagesFor, urlFor } from '../lib/notion';
import { t } from '../i18n/dict';
import type { Entry, Locale } from '../lib/types';

interface Props {
  entry: Entry;
  locale: Locale;
}
const { entry, locale } = Astro.props;

const entries = await getEntries();
const navPages = pagesFor(entries, locale).map((p) => ({ title: p.title, path: urlFor(p) }));
const homePath = locale === 'pl' ? '/pl/' : '/';

const translationPath = entry.translation ? urlFor(entry.translation) : undefined;
const translationLocale = entry.translation?.locale;

const description =
  entry.excerpt ??
  entry.content.find((b) => b.type === 'p' && b.html)?.html?.replace(/<[^>]+>/g, '').slice(0, 200);

const dateLabel =
  entry.type === 'article' && entry.publishedAt
    ? new Date(entry.publishedAt).toLocaleDateString(locale === 'pl' ? 'pl-PL' : 'en-GB', {
        year: 'numeric',
        month: 'long',
        day: 'numeric',
      })
    : undefined;
---

<BaseLayout
  locale={locale}
  title={entry.title}
  description={description}
  cover={entry.cover}
  homePath={homePath}
  navPages={navPages}
  translationPath={translationPath}
  translationLocale={translationLocale}
>
  <article class="entry">
    {
      entry.cover && (
        <div class="entry-cover">
          <Cover src={entry.cover} alt={entry.title} />
        </div>
      )
    }
    <header class="entry-header">
      <h1>{entry.title}</h1>
      {
        dateLabel && (
          <time datetime={entry.publishedAt}>
            {t('publishedOn', locale)}: {dateLabel}
          </time>
        )
      }
    </header>
    <ContentBody blocks={entry.content} />
    <p class="entry-back"><a href={homePath}>{t('backToHome', locale)}</a></p>
  </article>
</BaseLayout>

<style>
  .entry {
    max-width: var(--content-width);
    margin: 0 auto;
    padding-top: clamp(24px, 5vw, 48px);
  }
  .entry-cover {
    aspect-ratio: 16 / 9;
    border-radius: var(--radius);
    overflow: hidden;
    margin-bottom: var(--space-5);
  }
  .entry-header {
    margin-bottom: var(--space-5);
  }
  .entry-header h1 {
    margin: 0;
    font: 500 clamp(30px, 5vw, 48px) / 1.08 var(--font-serif);
    letter-spacing: -0.015em;
    color: var(--color-text);
  }
  .entry-header time {
    display: block;
    font: 400 12px var(--font-mono);
    color: var(--color-accent);
    margin-top: var(--space-3);
  }
  .entry-back {
    margin-top: var(--space-6);
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }
  .entry-back a {
    text-decoration: none;
    color: var(--color-faint);
  }
  .entry-back a:hover {
    color: var(--color-accent);
  }
</style>
