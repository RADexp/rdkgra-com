---
import '../styles/global.css';
import { t } from '../i18n/dict';
import type { Locale } from '../lib/types';

interface NavPage {
  title: string;
  path: string;
}

interface Props {
  locale: Locale;
  title: string;
  description?: string;
  cover?: string;
  homePath: string;
  navPages: NavPage[];
  // wersja w drugim języku (jeśli istnieje): do przełącznika i hreflang
  translationPath?: string;
  translationLocale?: Locale;
}

const {
  locale,
  title,
  description,
  cover,
  homePath,
  navPages,
  translationPath,
  translationLocale,
} = Astro.props;

const site = Astro.site ?? new URL('https://radekgrabarek.com');
const canonical = new URL(Astro.url.pathname, site).href;
const translationUrl = translationPath ? new URL(translationPath, site).href : undefined;

// hreflang: bieżąca wersja + tłumaczenie (jeśli jest) + x-default → wersja EN
const alternates: { hreflang: string; href: string }[] = [{ hreflang: locale, href: canonical }];
if (translationUrl && translationLocale) {
  alternates.push({ hreflang: translationLocale, href: translationUrl });
}
const enHref =
  locale === 'en' ? canonical : translationLocale === 'en' ? translationUrl : undefined;
if (enHref) alternates.push({ hreflang: 'x-default', href: enHref });

const fullTitle = `${title} — ${t('siteName', locale)}`;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonical} />

    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    {alternates.map((a) => <link rel="alternate" hreflang={a.hreflang} href={a.href} />)}

    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonical} />
    {cover && <meta property="og:image" content={cover} />}
    <meta name="twitter:card" content={cover ? 'summary_large_image' : 'summary'} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,400;0,500;0,700;1,400&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,400&display=swap"
      rel="stylesheet"
    />

    <slot name="head" />
  </head>
  <body>
    <header class="site-header">
      <nav class="site-nav" aria-label={locale === 'pl' ? 'Główna nawigacja' : 'Main navigation'}>
        <ul class="nav-links">
          <li><a class="nav-writing" href={homePath}>{t('navWriting', locale)}</a></li>
          {navPages.map((p) => (
            <li><a href={p.path}>{p.title}</a></li>
          ))}
        </ul>
        <div class="nav-right">
          {translationPath && (
            <div class="lang-toggle" aria-label={locale === 'pl' ? 'Przełącznik języka' : 'Language switcher'}>
              {locale === 'en' ? (
                <span class="lang-current">EN</span>
              ) : (
                <a class="lang-link" href={translationPath} rel="alternate" hreflang="en">EN</a>
              )}
              <span class="lang-sep">/</span>
              {locale === 'pl' ? (
                <span class="lang-current">PL</span>
              ) : (
                <a class="lang-link" href={translationPath} rel="alternate" hreflang="pl">PL</a>
              )}
            </div>
          )}
          <a class="brand" href={homePath}>radekgrabarek<span class="tld">.com</span></a>
        </div>
      </nav>
    </header>

    <main class="site-main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <p>© {new Date().getFullYear()} {t('siteName', locale)}</p>
        <p>radekgrabarek<span class="tld" style="color:var(--color-accent)">.com</span></p>
      </div>
    </footer>

    <!-- Zapamiętaj świadomy wybór języka, żeby auto-redirect na "/" go nie nadpisywał. -->
    <script is:inline>
      document.addEventListener(
        'click',
        function (e) {
          var a = e.target.closest && e.target.closest('.lang-link');
          if (a) {
            try {
              localStorage.setItem('langChosen', '1');
            } catch (_) {}
          }
        },
        true,
      );
    </script>
  </body>
</html>
